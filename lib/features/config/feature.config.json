{
  "feature": {
    "name": "habari",
    "label": "habari",
    "purpose": "Manage habari items",
    "maturity": 1,
    "permission": "habari"
  },
  "storage": {
    "remote": true,
    "local": false
  },
  "entities": {
    "habari": {
      "primary": true,
      "fields": {
        "id": {
          "type": "String",
          "primary": true,
          "readonly": true
        },
        "name": {
          "type": "String",
          "nullable": false,
          "validation": {
            "required": {
              "value": true,
              "message": "habari name is required"
            },
            "minLength": { "value": 2, "message": "Name too short" }
          }
        },
        "createdAt": {
          "type": "DateTime",
          "nullable": false,
          "readonly": true
        }
      },
      "relationships": {},
      "api": {
        "endpoint": "/habaris",
        "paginatable": false,
        "searchable": false
      },
      "ui": {
        "card": { "title": "name" },
        "detail": { "header": ["name"], "body": ["createdAt"] },
        "form": {
          "create": ["name"],
          "edit": ["name"]
        },
        "list": {
          "emptyMessage": "No habaris yet."
        }
      }
    }
  }
}
