{
  "feature": {
    "name": "actor_types",
    "label": "Actor Types",
    "purpose": "Platform admin CRUD for actor type reference data (manufacturer, distributor, pharmacy, etc.)",
    "maturity": 1,
    "permission": "admin_actor_types",
    "icon": "Icons.category_outlined",
    "activeIcon": "Icons.category"
  },
  "storage": {
    "remote": true,
    "local": false
  },
  "entities": {
    "ActorType": {
      "primary": true,
      "fields": {
        "id": {
          "type": "int",
          "primary": true,
          "readonly": true
        },
        "code": {
          "type": "String",
          "nullable": false,
          "validation": {
            "required": {
              "value": true,
              "message": "Code is required"
            },
            "minLength": {
              "value": 2,
              "message": "Code must be at least 2 characters"
            }
          }
        },
        "label": {
          "type": "String",
          "nullable": false,
          "validation": {
            "required": {
              "value": true,
              "message": "Label is required"
            }
          }
        },
        "isActive": {
          "type": "bool",
          "nullable": false
        },
        "createdAt": {
          "type": "DateTime",
          "nullable": false,
          "readonly": true
        }
      },
      "relationships": {},
      "api": {
        "endpoint": "/admin/actor-types",
        "paginatable": false,
        "searchable": false
      },
      "ui": {
        "card": {
          "title": "label",
          "subtitle": "code"
        },
        "detail": {
          "header": [
            "label",
            "code"
          ],
          "body": [
            "isActive",
            "createdAt"
          ]
        },
        "form": {
          "create": [
            "code",
            "label",
            "isActive"
          ],
          "edit": [
            "code",
            "label",
            "isActive"
          ]
        },
        "list": {
          "emptyMessage": "No actor types configured. Create the first one.",
          "searchBy": "label",
          "filterBy": "isActive"
        }
      }
    }
  }
}