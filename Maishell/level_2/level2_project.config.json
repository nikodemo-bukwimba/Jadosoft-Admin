{
  "feature": {
    "name":       "project",
    "label":      "Project",
    "purpose":    "Manage projects with lifecycle status tracking",
    "maturity":   2,
    "permission": "projects",
    "icon":       "Icons.folder_outlined",
    "activeIcon": "Icons.folder"
  },
  "storage": {
    "remote": true,
    "local":  false
  },
  "stateMachine": {
    "field":   "status",
    "states":  ["planning", "active", "onHold", "completed", "archived"],
    "initial": "planning",
    "transitions": [
      { "name": "activate",  "from": ["planning"],            "to": "active",    "label": "Start Project",   "permission": "project.activate" },
      { "name": "pause",     "from": ["active"],              "to": "onHold",    "label": "Put On Hold",     "permission": "project.pause" },
      { "name": "resume",    "from": ["onHold"],              "to": "active",    "label": "Resume",          "permission": "project.activate" },
      { "name": "complete",  "from": ["active"],              "to": "completed", "label": "Mark Complete",   "permission": "project.complete" },
      { "name": "archive",   "from": ["completed", "onHold"], "to": "archived",  "label": "Archive",         "permission": "project.archive" }
    ]
  },
  "entities": {
    "Project": {
      "primary": true,
      "fields": {
        "id": {
          "type":     "String",
          "primary":  true,
          "readonly": true
        },
        "name": {
          "type":     "String",
          "nullable": false,
          "validation": {
            "required":  { "value": true, "message": "Project name is required" },
            "minLength": { "value": 3,    "message": "Name must be at least 3 characters" }
          }
        },
        "description": {
          "type":     "String",
          "nullable": true
        },
        "budget": {
          "type":     "double",
          "nullable": true
        },
        "isPublic": {
          "type":     "bool",
          "nullable": false
        },
        "startDate": {
          "type":     "DateTime",
          "nullable": true
        },
        "createdAt": {
          "type":     "DateTime",
          "nullable": false,
          "readonly": true
        }
      },
      "relationships": {},
      "api": {
        "endpoint": "/projects"
      },
      "ui": {
        "card": {
          "title":    "name",
          "subtitle": "description"
        },
        "detail": {
          "header": ["name"],
          "body":   ["description", "budget", "isPublic", "startDate", "createdAt"]
        },
        "form": {
          "create": ["name", "description", "budget", "isPublic", "startDate"],
          "edit":   ["name", "description", "budget", "isPublic", "startDate"]
        },
        "list": {
          "emptyMessage": "No projects yet. Create your first project."
        }
      }
    }
  }
}
