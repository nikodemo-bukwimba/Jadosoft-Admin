{
  "feature": {
    "name": "actor",
    "label": "Actors",
    "purpose": "Platform admin management of actors — organizations, customers, and marketplace participants",
    "maturity": 1,
    "permission": "actors",
    "icon": "Icons.people_outlined",
    "activeIcon": "Icons.people"
  },
  "storage": {
    "remote": true,
    "local": true
  },
  "entities": {
    "Actor": {
      "primary": true,
      "fields": {
        "id": {
          "type": "String",
          "primary": true,
          "readonly": true
        },
        "displayName": {
          "type": "String",
          "nullable": false,
          "validation": {
            "required": {
              "value": true,
              "message": "Display name is required"
            },
            "minLength": {
              "value": 2,
              "message": "Name must be at least 2 characters"
            }
          }
        },
        "status": {
          "type": "String",
          "nullable": false,
          "validation": {
            "required": {
              "value": true,
              "message": "Status is required"
            }
          }
        },
        "createdAt": {
          "type": "DateTime",
          "nullable": false,
          "readonly": true
        },
        "updatedAt": {
          "type": "DateTime",
          "nullable": false,
          "readonly": true
        }
      },
      "relationships": {},
      "api": {
        "endpoint": "/actors",
        "paginatable": true,
        "searchable": true
      },
      "ui": {
        "card": {
          "title": "displayName",
          "subtitle": "status"
        },
        "detail": {
          "header": ["displayName", "status"],
          "body": ["createdAt", "updatedAt"]
        },
        "form": {
          "create": ["displayName", "status"],
          "edit": ["displayName", "status"]
        },
        "list": {
          "emptyMessage": "No actors found. Create your first actor."
        }
      }
    }
  }
}
